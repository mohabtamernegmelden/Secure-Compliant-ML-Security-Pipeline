# Production environment example
ENVIRONMENT=production
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Replace these values with strong secrets before deployment
JWT_SECRET_KEY=replace-with-strong-random-secret
REFRESH_JWT_SECRET_KEY=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY=local-dev-api-key-replace-in-production

# Optional Azure Key Vault integration
AZURE_KEYVAULT_URL=
