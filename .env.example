# Application Settings
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

# Security and JWT
# Run `openssl rand -hex 32` to generate secure keys
JWT_SECRET_KEY=supersecretjwtkeychangeinproduction12345
REFRESH_JWT_SECRET_KEY=supersecretrefreshjwtkeychangeinproduction12345
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY=local-dev-api-key-replace-in-production

# Azure Key Vault Configuration (Optional for local development)
AZURE_KEYVAULT_URL=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
